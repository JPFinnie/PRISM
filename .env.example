# OpenAI API Key — add your key here locally, and in Vercel project settings
# NEVER commit your actual key to git
OPENAI_API_KEY=sk-proj-...

# Alpha Vantage API Key for real-time stock quotes
# Get a free key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your-key-here

# Optional: set to "true" to bypass AI and return mock insights (useful for testing UI)
MOCK_AI=false
